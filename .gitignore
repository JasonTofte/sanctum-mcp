# --- Public-repo safety: never commit framework IP, secrets, or evidence ---

# Claude Code project config — contains local dev-tooling that MUST NOT ship
# to a public repo. settings.local.json, skills, hooks, agents all stay local.
.claude/

# Evidence / case data — never ships with source.
# Root-anchored so tests/fixtures/accuracy_corpus/cases/ is not excluded.
/cases/
/evidence/

# Evidence-image extensions — globbed so they apply EVERYWHERE. Without
# `**/`, a smuggled `tests/fixtures/<something>/disk.e01` could slip past
# a root-anchored `/*.e01` form. AC-19b regression tests pin these.
**/*.raw
**/*.e01
**/*.dd
**/*.img
**/*.mem
**/*.vmem
**/*.vmsn
ledger/
audit/
*.jsonl

# DFIR-Metric eval cache + run reports — license-clean reproduction.
# Upstream JSON (license: null) lives only on contributor machines; the
# public repo carries Sanctum's derivative metadata in
# tests/benchmarks/dfir_metric_subset.py. The fixture-smoke report is
# carved back in so AC-4 schema-reference can ship.
.cache/dfir-metric/
reports/eval-*.json
!reports/eval-*-fixture-smoke.json
# Carve-out: this fixture is the load-bearing pre-extension ledger for AC-7
# (T-3/T-4 oracle). Generated once via scripts/gen_pre_instrumentation_fixture.py
# and committed so verify_chain backwards-compat is testable on a fresh checkout.
!tests/fixtures/ledger_pre_instrumentation.jsonl

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# Secrets / env
.env
.env.*
!.env.example
*.pem
*.key
secrets/
# Carve-out: AC-7 fixture HMAC key — public, deterministic, test-only
# (paired with tests/fixtures/ledger_pre_instrumentation.jsonl above).
# A fresh checkout needs this to verify the pre-extension chain.
!tests/fixtures/ledger_pre_instrumentation.key

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Logs — root-anchored so tests/fixtures/accuracy_corpus/cases/smoke/logs/ is not excluded.
*.log
/logs/

# Private content — drafts, scratch notes, hackathon scoring/ground-truth,
# demo takes, copyrighted screenshots, transcripts, anything not for the
# public repo. Single top-level root by convention; see CLAUDE.md
# §"Private content lives in `/private/`".
/private/

# Session-shaped design scaffolding (Sherlock 8-step methodology). The durable
# design record is `docs/ADR_*.md`; the plan and test-matrix are process
# artifacts that age out of date quickly. Keeping them local also avoids
# leaking the upstream dev-framework dependency to the public repo (see
# `feedback_framework_integration_strategy.md`).
.sherlock-plan.md
.test-matrix.md

# Proposal output from `scripts/expand_subset.py` — reviewer diffs the
# proposed module against the live one, then either renames-into-place
# manually or re-runs with --write. The .proposed file itself never
# belongs in git.
*.proposed
