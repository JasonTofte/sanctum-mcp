# --- Public-repo safety: never commit framework IP, secrets, or evidence ---

# Claude Code project config — contains local dev-tooling that MUST NOT ship
# to a public repo. settings.local.json, skills, hooks, agents all stay local.
.claude/

# Evidence / case data — never ships with source
cases/
evidence/

# Evidence-image extensions — globbed so they apply EVERYWHERE. Without
# `**/`, a smuggled `tests/fixtures/<something>/disk.e01` could slip past
# a root-anchored `/*.e01` form. AC-19b regression tests pin these.
**/*.raw
**/*.e01
**/*.dd
**/*.img
**/*.mem
**/*.vmem
**/*.vmsn
ledger/
audit/
*.jsonl

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# Secrets / env
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Logs
*.log
logs/

# Private content — drafts, scratch notes, hackathon scoring/ground-truth,
# demo takes, copyrighted screenshots, transcripts, anything not for the
# public repo. Single top-level root by convention; see CLAUDE.md
# §"Private content lives in `/private/`".
/private/

# Session-shaped design scaffolding (Sherlock 8-step methodology). The durable
# design record is `docs/ADR_*.md`; the plan and test-matrix are process
# artifacts that age out of date quickly. Keeping them local also avoids
# leaking the upstream dev-framework dependency to the public repo (see
# `feedback_framework_integration_strategy.md`).
.sherlock-plan.md
.test-matrix.md
